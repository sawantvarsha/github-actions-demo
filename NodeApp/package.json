{
  "name": "client-self-service-portal",
  "version": "21.1.9",
  "scripts": {
    "ng": "ng",
    "start": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng serve --port 4200",
    "ssl": "ng serve --port 4200 --ssl",
    "server": "nodemon .\\server.js",
    "server2": "nodemon --trace-warnings .\\serverV2.js",
    "prebuild": "npm --no-git-tag-version version patch",
    "buildOld": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng build --base-href=/FiveStarPortal/ --aot=true",
    "build": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng build --base-href=/FinIQFiveStarPortal/ --aot=true",
    "build-publish": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng build --base-href=/FiveStarPortal/ --aot=true --output-path C://inetpub/wwwroot/FiveStarPortal",
    "post-build": "purgecss --css dist/FiveStarPortal/*.css --content dist/FiveStarPortal/index.html dist/FiveStarPortal/*.js --output dist/FiveStarPortal",
    "build-stats": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng build --stats-json --base-href=/FiveStarPortal/",
    "build-dev": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng build --source-map=false --configuration development --base-href=/FiveStarPortal/ --outputPath=dist_dev",
    "post-build-dev": "purgecss --css dist_dev/*.css --content dist_dev/index.html dist_dev/*.js --output dist_dev",
    "test": "ng test",
    "lint": "ng lint --fix",
    "e2e": "ng e2e",
    "aot": "node --max_old_space_size=12288 ./node_modules/@angular/cli/bin/ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "run:all": "node node_modules/@angular-architects/module-federation/src/server/mf-dev-server.js"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/module-federation": "^20.0.0",
    "@angular-devkit/build-webpack": "^0.2101.0",
    "@angular/material-moment-adapter": "21.1.1",
    "@angular/animations": "^21.1.1",
    "@angular/cdk": "^21.1.1",
    "@angular/common": "^21.1.1",
    "@angular/compiler": "^21.1.1",
    "@angular/core": "^21.1.1",
    "@angular/forms": "^21.1.1",
    "@angular/material": "21.1.1",
    "@angular/platform-browser": "^21.1.1",
    "@angular/platform-browser-dynamic": "^21.1.1",
    "@angular/router": "^21.1.1",
    "@mat-datetimepicker/core": "^15.0.2",
    "@mat-datetimepicker/moment": "^15.0.2",
    "@ngx-translate/core": "16.0.4",
    "@ngx-translate/http-loader": "16.0.1",
    "angular-auth-oidc-client": "^21.0.0",
    "angular-google-charts": "^16.1.0",
    "angular-plotly.js": "^5.2.2",
    "apexcharts": "^5.3.6",
    "chart.js": "4.5.0",
    "crypto-js": "4.2.0",
    "file-saver": "^2.0.5",
    "html2canvas": "^1.4.1",
    "jquery": "^4.0.0",
    "json2xml": "^0.1.3",
    "jspdf": "4.0.0",
    "jspdf-autotable": "5.0.7",
    "moment": "^2.30.1",
