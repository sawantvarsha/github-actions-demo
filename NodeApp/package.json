    "webpack-dev-server": "^5.2.3",
    "ngx-xml2json": "^1.0.2",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.1",
    "@angular-eslint/schematics": "^21.1.0",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.1",
    "@types/jasmine": "^5.1.15",
    "@types/jquery": "3.5.33",
    "@types/node": "25.0.9",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
